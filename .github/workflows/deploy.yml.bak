name: Build and Deploy to GitHub Pages
on:
  push:
    branches: [ main ]
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout 🛎️
        uses: actions/checkout@v3

      - name: Create Firebase Config File
        run: |
          # 创建包含Firebase秘密配置的文件
          mkdir -p _build/components
          
          # 复制所有文件到构建目录
          cp -r index.html components .nojekyll README.md _build/
          
          # 创建注入了密钥的Firebase配置文件
          cat > _build/components/firebase-config.js << EOF
          // Firebase访客数据存储模块
          // 注意：此文件由GitHub Actions自动生成，包含从仓库Secrets注入的配置

          import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
          import { 
            getFirestore, 
            collection, 
            addDoc, 
            getDocs, 
            where, 
            query, 
            updateDoc, 
            doc, 
            orderBy, 
            limit,
            getDoc,
            setDoc,
            deleteDoc 
          } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
          import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

          // Firebase配置 - 由GitHub Actions注入
          const firebaseConfig = {
            apiKey: "${{ secrets.FIREBASE_API_KEY }}",
            authDomain: "${{ secrets.FIREBASE_AUTH_DOMAIN }}",
            projectId: "${{ secrets.FIREBASE_PROJECT_ID }}",
            storageBucket: "${{ secrets.FIREBASE_STORAGE_BUCKET }}",
            messagingSenderId: "${{ secrets.FIREBASE_MESSAGING_SENDER_ID }}",
            appId: "${{ secrets.FIREBASE_APP_ID }}"
          };
          EOF
          
          # 附加原始文件中firebase-config.js的其余部分(跳过配置部分)
          sed -n '/let app;/,$p' components/firebase-config.js >> _build/components/firebase-config.js

      - name: Deploy to GitHub Pages 🚀
        uses: JamesIves/github-pages-deploy-action@v4
        with:
          folder: _build  # 指定构建输出的文件夹
          branch: gh-pages # 部署到的分支
          clean: true # 清理旧文件